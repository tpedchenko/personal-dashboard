# =============================================================================
# Personal Dashboard — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Database (required) ---
# PostgreSQL connection string (via PgBouncer in production)
DATABASE_URL="postgresql://pd:your_password@localhost:5432/pd"
# Direct PostgreSQL URL for Prisma migrations (bypasses PgBouncer)
DIRECT_DATABASE_URL="postgresql://pd:your_password@localhost:5432/pd"
# PostgreSQL password (used by docker-compose)
PG_PASSWORD="your_password"

# --- Authentication (required) ---
# NextAuth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret"
NEXTAUTH_SECRET="generate-a-random-secret"
# Base URL of your app
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (required) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Encryption (required) ---
# AES-GCM key for encrypting secrets in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="64-character-hex-string"

# --- Redis (optional, recommended) ---
REDIS_URL="redis://:your_redis_password@localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="your_redis_password"

# --- Ollama / AI (optional) ---
# Local LLM for AI chat and embeddings
OLLAMA_BASE_URL="http://ollama:11434/v1"

# --- Freqtrade (optional) ---
# Trading bot integration
FREQTRADE_URL="http://localhost:8082"
FREQTRADE_USER="freqtrader"
FREQTRADE_PASS="your_freqtrade_password"

# --- Telegram (optional) ---
# Notifications via Telegram bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# --- Garmin (optional) ---
# MFA API token for Garmin Connect sync
GARMIN_MFA_API_TOKEN="your-garmin-mfa-token"

# --- Demo mode (optional) ---
# Secret for demo access without Google OAuth
DEMO_SECRET="your-demo-secret"

# --- Database backend (optional) ---
# Used by scheduler; defaults to PostgreSQL
DB_BACKEND="postgresql"
